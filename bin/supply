#!/usr/bin/env bash
# ================================================================
# pnpm-prebundled-nodejs_buildpack — supply
#
# Provides the Node.js and pnpm runtimes.
# Does NOT run any install command.
# ================================================================
set -euo pipefail

BUILD_DIR="$1"
CACHE_DIR="$2"
DEPS_DIR="$3"
DEPS_IDX="$4"

BUILDPACK_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
source "${BUILDPACK_DIR}/lib/utils.sh"

# ── Determine versions ──────────────────────────────────────────

REQUESTED_NODE=$(read_package_field "${BUILD_DIR}/package.json" "engines.node")
NODE_VERSION=$(resolve_node_version "${REQUESTED_NODE}")

PACKAGE_MANAGER_FIELD=$(read_package_field "${BUILD_DIR}/package.json" "packageManager")
if echo "$PACKAGE_MANAGER_FIELD" | grep -q "pnpm@"; then
  PNPM_VERSION=$(echo "$PACKAGE_MANAGER_FIELD" | sed 's/pnpm@//')
else
  PNPM_VERSION="${PNPM_DEFAULT_VERSION}"
fi

# Allow env var overrides
NODE_VERSION="${NODE_OVERRIDE_VERSION:-$NODE_VERSION}"
PNPM_VERSION="${PNPM_OVERRIDE_VERSION:-$PNPM_VERSION}"

log_info "Supply phase starting"
log_detail "Node.js version: v${NODE_VERSION} (requested: '${REQUESTED_NODE:-not set}')"
log_detail "pnpm version:    v${PNPM_VERSION}"

# ── Install Node.js ─────────────────────────────────────────────

NODE_CACHE="${CACHE_DIR}/node-v${NODE_VERSION}-linux-x64.tar.gz"
NODE_INSTALL_DIR="${DEPS_DIR}/${DEPS_IDX}/node"

if [ -f "$NODE_CACHE" ]; then
  log_info "Using cached Node.js v${NODE_VERSION}"
else
  NODE_URL="https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.gz"
  log_info "Downloading Node.js v${NODE_VERSION}"
  log_detail "${NODE_URL}"

  HTTP_CODE=$(curl -sL -w "%{http_code}" -o "$NODE_CACHE" "$NODE_URL")
  if [ "$HTTP_CODE" != "200" ]; then
    log_error "Download failed with HTTP ${HTTP_CODE}"
    log_error "Check that Node.js v${NODE_VERSION} exists at nodejs.org/dist/"
    rm -f "$NODE_CACHE"
    exit 1
  fi

  # Verify SHA256 checksum
  SHASUMS_URL="https://nodejs.org/dist/v${NODE_VERSION}/SHASUMS256.txt"
  EXPECTED_SHA=$(curl -sL "$SHASUMS_URL" | grep "node-v${NODE_VERSION}-linux-x64.tar.gz" | awk '{print $1}' || true)

  if [ -n "$EXPECTED_SHA" ]; then
    ACTUAL_SHA=$(sha256sum "$NODE_CACHE" | awk '{print $1}')
    if [ "$ACTUAL_SHA" != "$EXPECTED_SHA" ]; then
      log_error "SHA256 checksum mismatch for Node.js v${NODE_VERSION}"
      log_error "Expected: ${EXPECTED_SHA}"
      log_error "Actual:   ${ACTUAL_SHA}"
      rm -f "$NODE_CACHE"
      exit 1
    fi
    log_detail "SHA256 checksum verified"
  else
    log_warn "Could not fetch SHASUMS256.txt — skipping checksum verification"
  fi
fi

mkdir -p "$NODE_INSTALL_DIR"
tar xzf "$NODE_CACHE" -C "$NODE_INSTALL_DIR" --strip-components=1

# ── Install pnpm ────────────────────────────────────────────────
# Available for lifecycle scripts and debugging, not for install.

PNPM_CACHE="${CACHE_DIR}/pnpm-v${PNPM_VERSION}.tgz"
PNPM_INSTALL_DIR="${DEPS_DIR}/${DEPS_IDX}/pnpm"

if [ -f "$PNPM_CACHE" ]; then
  log_info "Using cached pnpm v${PNPM_VERSION}"
else
  PNPM_URL="https://registry.npmjs.org/pnpm/-/pnpm-${PNPM_VERSION}.tgz"
  log_info "Downloading pnpm v${PNPM_VERSION}"

  HTTP_CODE=$(curl -sL -w "%{http_code}" -o "$PNPM_CACHE" "$PNPM_URL")
  if [ "$HTTP_CODE" != "200" ]; then
    log_warn "pnpm download failed (HTTP ${HTTP_CODE}) — continuing without pnpm binary"
    rm -f "$PNPM_CACHE"
  else
    # Verify SHA1 checksum against npm registry metadata
    PNPM_META_URL="https://registry.npmjs.org/pnpm/${PNPM_VERSION}"
    EXPECTED_SHA1=$(curl -sL "$PNPM_META_URL" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data['dist']['shasum'])
except (KeyError, TypeError, json.JSONDecodeError):
    pass
" 2>/dev/null || true)

    if [ -n "$EXPECTED_SHA1" ]; then
      ACTUAL_SHA1=$(sha1sum "$PNPM_CACHE" | awk '{print $1}')
      if [ "$ACTUAL_SHA1" != "$EXPECTED_SHA1" ]; then
        log_error "SHA1 checksum mismatch for pnpm v${PNPM_VERSION}"
        log_error "Expected: ${EXPECTED_SHA1}"
        log_error "Actual:   ${ACTUAL_SHA1}"
        rm -f "$PNPM_CACHE"
        exit 1
      fi
      log_detail "SHA1 checksum verified"
    else
      log_warn "Could not fetch npm registry metadata — skipping pnpm checksum verification"
    fi
  fi
fi

if [ -f "$PNPM_CACHE" ]; then
  mkdir -p "$PNPM_INSTALL_DIR"
  tar xzf "$PNPM_CACHE" -C "$PNPM_INSTALL_DIR" --strip-components=1
fi

# ── Set up PATH via profile.d ───────────────────────────────────

PROFILE_DIR="${DEPS_DIR}/${DEPS_IDX}/profile.d"
mkdir -p "$PROFILE_DIR"

cat <<'PROFILE' > "${PROFILE_DIR}/000_node.sh"
# Auto-generated by pnpm-prebundled-nodejs_buildpack
export NODE_HOME="${DEPS_DIR}/${DEPS_IDX}/node"
export PATH="${NODE_HOME}/bin:${DEPS_DIR}/${DEPS_IDX}/pnpm/bin:${PATH}"

# Memory tuning: set max_old_space_size to 75% of available memory
if [ -n "${MEMORY_LIMIT:-}" ]; then
  MEMORY_MB=$(echo "$MEMORY_LIMIT" | sed 's/[mM]$//')
  export NODE_OPTIONS="--max-old-space-size=$(( MEMORY_MB * 75 / 100 )) ${NODE_OPTIONS:-}"
fi

export NODE_ENV="${NODE_ENV:-production}"

# Web process defaults (used by @sap/cds, express clustering, etc.)
export WEB_MEMORY="${WEB_MEMORY:-512}"
export WEB_CONCURRENCY="${WEB_CONCURRENCY:-1}"

# SSL/TLS: ensure Node.js >= 20 finds system CA certificates
export SSL_CERT_DIR="${SSL_CERT_DIR:-/etc/ssl/certs}"
PROFILE

# Replace placeholders with actual values (profile.d scripts
# don't receive these as arguments at runtime)
sed -i "s|\${DEPS_DIR}|${DEPS_DIR}|g" "${PROFILE_DIR}/000_node.sh"
sed -i "s|\${DEPS_IDX}|${DEPS_IDX}|g" "${PROFILE_DIR}/000_node.sh"

# ── Create symlinks for immediate use in finalize phase ─────────

mkdir -p "${DEPS_DIR}/${DEPS_IDX}/bin"
ln -sf "${NODE_INSTALL_DIR}/bin/node" "${DEPS_DIR}/${DEPS_IDX}/bin/node"
ln -sf "${NODE_INSTALL_DIR}/bin/npm"  "${DEPS_DIR}/${DEPS_IDX}/bin/npm"
ln -sf "${NODE_INSTALL_DIR}/bin/npx"  "${DEPS_DIR}/${DEPS_IDX}/bin/npx"

if [ -f "${PNPM_INSTALL_DIR}/bin/pnpm.cjs" ]; then
  cat <<PNPM_WRAPPER > "${DEPS_DIR}/${DEPS_IDX}/bin/pnpm"
#!/usr/bin/env bash
exec node "\$(dirname "\$(readlink -f "\$0")")/../pnpm/bin/pnpm.cjs" "\$@"
PNPM_WRAPPER
  chmod +x "${DEPS_DIR}/${DEPS_IDX}/bin/pnpm"
fi

# Make available to subsequent buildpack phases
export PATH="${NODE_INSTALL_DIR}/bin:${DEPS_DIR}/${DEPS_IDX}/bin:${PATH}"

log_info "Supply phase complete"
log_detail "node $(node --version)"
